# docker compose 환경 변수 예시 파일
# 사용법: 이 파일을 .env로 복사한 뒤 값을 실제 환경에 맞게 수정하세요.
#   cp .env.example .env
# 값을 지정하지 않으면 docker-compose.yml의 기본값(개발용)이 사용됩니다.

# MySQL root 비밀번호 (userdb/bookingdb/stockdb/paymentdb 공통)
MYSQL_ROOT_PASSWORD=rootpassword

# JWT 서명 키 (Base64 인코딩 문자열, 운영 환경에서는 반드시 교체)
JWT_SECRET=c3BhcnRhLW1zYS1ob3RlbC1ib29raW5nLXNlcnZpY2Utand0LXNlY3JldC1rZXktMjAyNg==

# Grafana 관리자 계정
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
